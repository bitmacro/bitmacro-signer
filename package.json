{
  "name": "@bitmacro/bitmacro-signer",
  "version": "0.4.14",
  "description": "Managed NIP-46 bunker for the BitMacro ecosystem — secure remote signing without exposing nsec",
  "private": false,
  "license": "MIT",
  "author": "BitMacro <contact@bitmacro.io>",
  "homepage": "https://signer.bitmacro.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitmacro/bitmacro-signer.git"
  },
  "bugs": {
    "url": "https://github.com/bitmacro/bitmacro-signer/issues"
  },
  "keywords": [
    "nostr",
    "nip-46",
    "bunker",
    "signer",
    "bitmacro",
    "nostr-connect",
    "webcrypto",
    "aes-gcm"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:daemon": "esbuild src/daemon/index.ts --bundle --platform=node --target=node22 --format=cjs --outfile=dist/daemon/index.js --alias:@=./src",
    "start": "next start",
    "lint": "eslint .",
    "i18n:emit": "node scripts/i18n-emit.mjs",
    "ingest:signer": "tsx scripts/ingest-signer-corpus.ts",
    "ingest:signer:replace": "tsx scripts/ingest-signer-corpus.ts --replace",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bitmacro/relay-connect": "^0.1.1",
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.76.1",
    "clsx": "^2.1.0",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.460.0",
    "next": "^16",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "nostr-tools": "^2.23.3",
    "openai": "^4.85.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19",
    "react-dom": "^19",
    "tailwind-merge": "^2.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "esbuild": "^0.25.0",
    "eslint": "^9",
    "eslint-config-next": "^16",
    "tailwindcss": "^4",
    "tsx": "^4.19.3",
    "typescript": "^5.7",
    "vitest": "^3.2.4"
  }
}
