# --- Público (browser) ---
# URL base da aplicação (bunker URI, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase — base de dados partilhada do ecossistema BitMacro
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Relay Nostr por defeito (UI + cliente WS)
NEXT_PUBLIC_RELAY_URL=wss://relay.bitmacro.io

# --- Servidor ---
# TTL em segundos para manter nsec desencriptada em RAM durante sessão activa (política operacional)
SIGNER_SESSION_TTL_SECONDS=3600

# Opcional: chave de serviço Supabase só se Route Handlers precisarem de bypass RLS (avaliar antes de activar)
# SUPABASE_SERVICE_ROLE_KEY=
