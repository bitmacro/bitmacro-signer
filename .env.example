# --- Público (browser) ---
# URL base da aplicação (bunker URI, redirects)
NEXT_PUBLIC_APP_URL=https://signer.bitmacro.io

# Supabase — base de dados partilhada do ecossistema BitMacro
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Relay Nostr (UI, bunker_uri em POST /api/sessions)
# NIP-46: relay público (.cloud) sem whitelist — bom para validar o assinador; produção pode usar .io (privado + whitelist)
NEXT_PUBLIC_RELAY_URL=wss://relay.bitmacro.cloud

# --- Servidor ---
# TTL em segundos para manter nsec desencriptada em RAM durante sessão activa (política operacional)
SIGNER_SESSION_TTL_SECONDS=3600

# Opcional: TTL em ms para o loop NIP-46 (`startBunker`) manter nsec em RAM (default 24h)
# BUNKER_SESSION_RAM_TTL_MS=86400000

# Service role — obrigatório para `src/lib/session/app-keys.ts` (tabelas signer_* com RLS sem políticas)
SUPABASE_SERVICE_ROLE_KEY=

# Cookie de sessão httpOnly (JWT HS256) — mínimo ~16 caracteres; gerar valor aleatório forte em produção
AUTH_SESSION_SECRET=

# --- Daemon (Dockerfile.daemon / processo 24/7 no self-host) ---
# Lista de UUIDs BitMacro Identity (signer_vaults.identity_id), separados por vírgula — bunker NIP-46 por identidade.
# Em Vercel não corres; no server usa-se com `docker compose` ou só o serviço `daemon`.
DAEMON_IDENTITY_IDS=

# Passphrase do cofre (a mesma que desbloqueias na UI) — necessária para o daemon desencriptar o vault em Supabase.
# Sem isto o processo mantém-se vivo e re-tenta até existir vault + passphrase válida.
DAEMON_VAULT_PASSPHRASE=

# Opcional: intervalos em ms (mínimo 1000)
# DAEMON_HEALTHCHECK_INTERVAL_MS=30000
# DAEMON_VAULT_RETRY_INTERVAL_MS=60000
