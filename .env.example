# --- Public (browser) ---
# App base URL (bunker URI, redirects). Also used for SEO: sitemap.xml, robots.txt, JSON-LD.
NEXT_PUBLIC_APP_URL=https://signer.bitmacro.io

# Optional: full git SHA for this deployment — shown in UI and GET /api/build-info (verify link to GitHub).
# CI / Docker: pass the commit so users can match the running app to public source (supply-chain transparency).
# Vercel sets VERCEL_GIT_COMMIT_SHA automatically; use this for self-hosted images if needed.
# SIGNER_GIT_COMMIT=

# Supabase — shared BitMacro ecosystem database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Nostr relay (UI; baked into the Next client build)
# NIP-46: public relay (.cloud) without whitelist — good for testing the signer; production may use .io (private + whitelist)
NEXT_PUBLIC_RELAY_URL=wss://relay.bitmacro.cloud

# Same relay, read at runtime on the server (Docker / next start).
# Use for bunker_uri in POST /api/sessions without rebuilding the image; overrides NEXT_PUBLIC_RELAY_URL.
RELAY_URL=wss://relay.bitmacro.cloud

# --- Server ---
# TTL in seconds to keep decrypted nsec in RAM during an active session (operational policy)
SIGNER_SESSION_TTL_SECONDS=3600

# Optional: TTL in ms for the NIP-46 loop (`startBunker`) to retain nsec in RAM (default 24h)
# BUNKER_SESSION_RAM_TTL_MS=86400000

# Service role — required for `src/lib/session/app-keys.ts` (signer_* tables with RLS and no policies)
SUPABASE_SERVICE_ROLE_KEY=

# Optional (self-host): Node service-role only — HTTP base for REST/RPC when this host cannot reach *.supabase.co (VPS relay).
# Leave unset to use NEXT_PUBLIC_SUPABASE_URL for server-side too. Browser code always uses NEXT_PUBLIC_SUPABASE_URL.
# SUPABASE_SERVICE_ROLE_URL=http://10.0.0.1:8091

# httpOnly session cookie (JWT HS256) — at least ~16 chars; use a strong random value in production
AUTH_SESSION_SECRET=

# --- Self-host: signer-web → signer-daemon (HTTP on Docker network) ---
# If both are set, unlock forwards nsec to the daemon after decrypt; Next does not run the NIP-46 loop in-process.
# Internal URL only (e.g. http://signer-daemon:47777). On Vercel leave empty — uses local startBunker on unlock.
# DAEMON_INTERNAL_URL=http://signer-daemon:47777
# Strong shared token (same in signer-daemon container); do not expose to the internet.
# DAEMON_INTERNAL_TOKEN=

# --- Daemon (Dockerfile.daemon / 24/7 process in self-host) ---
# DAEMON_INTERNAL_TOKEN=   # required — same value as signer-web
# DAEMON_INTERNAL_PORT=47777 # optional (default 47777)

# --- Docs assistant (RAG) — /api/help/chat ---
# OPENAI_API_KEY=
# OPENAI_HTTP_TIMEOUT_MS=90000   # optional; per-request timeout (ms), default 90000, max 300000
# OPENAI_BASE_URL=       # optional; default https://api.openai.com/v1. Use if the app host cannot reach OpenAI directly
#                        # (firewall / ISP): point to a reachable HTTPS reverse proxy or AI gateway (same /v1 paths).
# OPENAI_CHAT_MODEL=     # optional (default gpt-4o-mini in code; bitmacro-server compose may omit)
# RAG_MIN_SIMILARITY=    # optional (default 0.32)
# Self-host Docker: bitmacro-server compose maps OPENAI_API_KEY (and optionally OPENAI_BASE_URL) → signer-web.
# Optional: override public URLs for cross-product RAG hints (default signer / identity in code).
# HELP_PRODUCT_URL_SIGNER=https://signer.bitmacro.io
# HELP_PRODUCT_URL_IDENTITY=https://id.bitmacro.io
